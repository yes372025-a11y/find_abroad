# Copy this file to .env and fill in your values.
# Run: cp .env.example .env

# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_DEBUG=false
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=find_abroad
POSTGRES_USER=find_abroad_user
POSTGRES_PASSWORD=change_me_strong_password

# NOTE: DATABASE_URL is constructed by docker-compose from the POSTGRES_* vars above.
# If running locally without Docker, set this manually:
# DATABASE_URL=postgresql+asyncpg://find_abroad_user:change_me_strong_password@localhost:5432/find_abroad
# When using docker-compose, this line is overridden by the environment: block and
# you do NOT need to set it here — the compose file builds it from POSTGRES_* vars.
DATABASE_URL=postgresql+asyncpg://find_abroad_user:change_me_strong_password@postgres:5432/find_abroad

# ─── Redis ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Set REDIS_PASSWORD here. The REDIS_URL is constructed by docker-compose.
# Do NOT set REDIS_PASSWORD separately if it is already embedded in REDIS_URL —
# the backend reads it from the URL itself.
REDIS_PASSWORD=change_me_redis_password
# REDIS_URL is set by docker-compose environment: block. For local dev without Docker:
# REDIS_URL=redis://:change_me_redis_password@localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Strapi CMS ────────────────────────────────────────────────────────────────
STRAPI_URL=http://strapi:1337
STRAPI_API_TOKEN=

# ─── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change_me_master_key

# ─── Listmonk Email ────────────────────────────────────────────────────────────
LISTMONK_URL=http://listmonk:9000
LISTMONK_USERNAME=listmonk_admin
LISTMONK_PASSWORD=change_me_listmonk_pass

# ─── PostHog Analytics ─────────────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=

# ─── ERPNext CRM ───────────────────────────────────────────────────────────────
ERPNEXT_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ─── Ollama AI ─────────────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ─── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=pdf,doc,docx,jpg,jpeg,png

# ─── Frontend ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL is the URL the *browser* uses to call the backend.
# For local Docker dev: use localhost (browser can reach it via the mapped port)
# For production: use your real domain e.g. https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_CALCOM_LINK=https://cal.com/your-org
