# Copy this file to .env and fill in your values.

# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_DEBUG=false
CORS_ORIGINS=http://localhost:3000,https://3xt8kq12-3000.inc1.devtunnels.ms

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=find_abroad
POSTGRES_USER=find_abroad_user
POSTGRES_PASSWORD=change_me_strong_password

# NOTE: DATABASE_URL is constructed by docker-compose from the POSTGRES_* vars above.
# If running locally without Docker, set this manually:
# DATABASE_URL=postgresql+asyncpg://find_abroad_user:change_me_strong_password@localhost:5432/find_abroad
DATABASE_URL=postgresql+asyncpg://find_abroad_user:change_me_strong_password@postgres:5432/find_abroad

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Default Counselor Account (seeded on first boot) ──────────────────────────
# Change these before first run. The seed script creates this account if it
# doesn't already exist — safe to re-run, will NOT overwrite an existing account.
COUNSELOR_EMAIL=counselor@findabroad.com
COUNSELOR_PASSWORD=change_me_counselor_password
COUNSELOR_NAME=Find Abroad Counselor

# ─── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=pdf,doc,docx,jpg,jpeg,png

# ─── Frontend ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL is the URL the *browser* uses to call the backend.
# For local Docker dev: use localhost (browser can reach it via the mapped port)
# For production: use your real domain e.g. https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CALCOM_LINK=https://cal.com/your-org
NEXT_PUBLIC_WHATSAPP_NUMBER=7845791797
